{
  "name": "aetherforge",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "db:migrate": "bash scripts/db/migrate.sh",
    "db:seed": "bash scripts/db/seed.sh",
    "test:smoke:pre-phase3": "python3 scripts/tests/pre_phase3_smoke.py",
    "test:smoke:mvp": "python3 scripts/tests/mvp_smoke.py",
    "job:flashcards:refresh": "bash scripts/jobs/refresh_flashcards_queue.sh",
    "health:check": "bash scripts/jobs/check_internal_health.sh",
    "test:smoke:resources-concurrency": "python3 scripts/tests/resources_concurrency_smoke.py",
    "test:smoke:milestones-concurrency": "python3 scripts/tests/milestones_concurrency_smoke.py",
    "test:smoke:collab-least-privilege": "python3 scripts/tests/collab_least_privilege_smoke.py",
    "test:smoke:collab-role-conflict": "python3 scripts/tests/collab_role_conflict_smoke.py",
    "test:smoke:collab-revoke-conflict": "python3 scripts/tests/collab_revoke_conflict_smoke.py",
    "test:smoke:phase6-hardening": "bash scripts/tests/run_phase6_hardening_smoke.sh",
    "test:smoke:phase7-reliability": "bash scripts/tests/run_phase7_reliability_smoke.sh",
    "test:smoke:ai-connection-required": "python3 scripts/tests/ai_connection_required_smoke.py",
    "test:quality:ai-schema": "python3 scripts/tests/ai_quality_gate.py --min-success-rate 95 --iterations 20 --require-connected-provider",
    "test:smoke:internal-health": "python3 scripts/tests/internal_health_smoke.py",
    "test:smoke:internal-health-state-matrix": "python3 scripts/tests/internal_health_state_matrix_smoke.py",
    "test:smoke:internal-jobs": "python3 scripts/tests/internal_jobs_smoke.py",
    "test:smoke:internal-jobs-overlap": "python3 scripts/tests/internal_jobs_overlap_smoke.py"
  },
  "dependencies": {
    "next": "^15.1.0",
    "pg": "^8.18.0",
    "playwright": "^1.58.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/pg": "^8.16.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.17.0",
    "eslint-config-next": "^15.1.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.16",
    "typescript": "^5.7.2"
  }
